# Speech-to-text (faster-whisper). First run downloads weights.
WHISPER_MODEL=small
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
WHISPER_BEAM_SIZE=5

# Text-to-speech (Piper). Run: python download_models.py
PIPER_VOICE=en_US-lessac-medium

# Allow browser calls from web app
CORS_ORIGINS=http://localhost:3000,http://localhost:3099
