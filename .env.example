# Phase 4 — configure each service in its own folder:
#
# services/ollama/.env     — OLLAMA_MODEL, OLLAMA_BASE_URL, TOPIC_STRICT_MODE
# services/web/.env        — NEXT_PUBLIC_OLLAMA_SERVICE_URL, NEXT_PUBLIC_SPEECH_URL
# services/speech/.env     — WHISPER_MODEL, PIPER_VOICE, CORS_ORIGINS

# Quick reference (defaults):
# Web UI:        http://localhost:3000
# Ollama API:    http://localhost:4000
# Speech API:    http://127.0.0.1:8000
# Ollama daemon: http://localhost:11434
